# ReBath IT Helper — environment variables
# Copy the relevant values into your hosting environment (Railway, Azure, etc.).
# Do NOT commit real secrets to git.

# --- Microsoft Teams bot auth (required) ---
# These authenticate the bot with the Bot Framework / Microsoft Entra.
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=
# BOT_ID is used as a fallback for CLIENT_ID if CLIENT_ID is unset.
BOT_ID=
# BOT_TYPE is one of: MultiTenant | SingleTenant | UserAssignedMsi
BOT_TYPE=MultiTenant

# --- Access control (strongly recommended for production) ---
# The Entra tenant GUID allowed to use this bot. If unset, the bot replies to ANY
# tenant — fine for local/playground, not for production.
ALLOWED_TENANT_ID=

# --- OpenAI (optional, enables the AI triage + field extraction) ---
# If unset, the bot still works using its keyword rules, just without AI pre-fill.
OPENAI_API_KEY=

# --- ServiceNow (required to create real incidents) ---
# Without these, confirmed tickets are saved locally as LOCAL-xxxxxx but NOT sent.
# SERVICENOW_INSTANCE accepts either the subdomain ("yourcompany") or a full URL
# ("https://yourcompany.service-now.com").
SERVICENOW_INSTANCE=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
# Optional: sys_id of a fallback caller when the Teams user can't be matched.
SERVICENOW_DEFAULT_CALLER_ID=
# Optional: sys_id of the assignment group new incidents should land in.
SERVICENOW_ASSIGNMENT_GROUP=

# --- Runtime ---
PORT=3978
